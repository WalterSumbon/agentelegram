{
  "name": "agentelegram",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native chat platform where agents are first-class citizens",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "build:shared": "npm run build -w packages/shared",
    "build:server": "npm run build -w packages/server",
    "build:web": "npm run build -w packages/web"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
