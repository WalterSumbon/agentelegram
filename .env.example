# PostgreSQL connection string
DATABASE_URL=postgresql://localhost:5432/agentelegram

# Server port
PORT=4000

# JWT secret (generate a random string for production!)
JWT_SECRET=change-me-to-a-random-secret

# JWT token lifetime (e.g. '7d', '24h', '30m')
JWT_EXPIRES_IN=7d

# WebSocket auth timeout (ms) — how long a client has to send auth after connecting
WS_AUTH_TIMEOUT_MS=10000

# WebSocket management request timeout (ms) — how long to wait for agent mgmt response
WS_MGMT_TIMEOUT_MS=15000

# Frontend dev server port
DEV_PORT=5173

# Backend URL for Vite proxy (frontend dev server proxies API/WS requests here)
BACKEND_URL=http://localhost:4000
